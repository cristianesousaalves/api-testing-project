    {
      "name": "01 - Happy Path",
      "description": "Fluxos positivos - cenarios onde tudo funciona como esperado",
      "item": [
        {
          "name": "GET - Listar Usuarios (Pagina 1)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users?page=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code deve ser 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time menor que 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('Deve retornar lista de usuarios', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "    pm.expect(jsonData.data.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Cada usuario deve ter id, email, first_name, last_name', function () {",
                  "    const jsonData = pm.response.json();",
                  "    jsonData.data.forEach(function(user) {",
                  "        pm.expect(user).to.have.property('id');",
                  "        pm.expect(user).to.have.property('email');",
                  "        pm.expect(user).to.have.property('first_name');",
                  "        pm.expect(user).to.have.property('last_name');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Header Content-Type deve ser application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "// Salvar primeiro userId para uso posterior",
                  "const jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.length > 0) {",
                  "    pm.collectionVariables.set('userId', jsonData.data[0].id);",
                  "    pm.collectionVariables.set('userEmail', jsonData.data[0].email);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET - Buscar Usuario por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code deve ser 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Deve retornar dados do usuario', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "    pm.expect(jsonData.data).to.have.property('email');",
                  "    pm.expect(jsonData.data).to.have.property('first_name');",
                  "    pm.expect(jsonData.data).to.have.property('last_name');",
                  "    pm.expect(jsonData.data).to.have.property('avatar');",
                  "});",
                  "",
                  "pm.test('ID retornado deve ser um numero valido', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.id).to.be.a('number');",
                  "    pm.expect(jsonData.data.id).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        },
