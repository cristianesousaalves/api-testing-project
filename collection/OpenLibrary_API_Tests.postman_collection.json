  "item": [
    {
      "name": "01 - Happy Path",
      "description": "Fluxos positivos - buscas que retornam resultados validos",
      "item": [
        {
          "name": "GET - Buscar Livro por Titulo",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/search.json?q=the+lord+of+the+rings&limit=5",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "search.json"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "the+lord+of+the+rings"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code deve ser 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time menor que 5000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});",
                  "",
                  "pm.test('Deve retornar resultados de busca', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('docs');",
                  "    pm.expect(json.docs).to.be.an('array');",
                  "    pm.expect(json.docs.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('Cada livro deve ter titulo e autor', function () {",
                  "    const json = pm.response.json();",
                  "    json.docs.forEach(function(book) {",
                  "        pm.expect(book).to.have.property('title');",
                  "        pm.expect(book).to.have.property('author_name');",
                  "    });",
                  "});",
                  "",
                  "// Salvar key do primeiro livro",
                  "const json = pm.response.json();",
                  "if (json.docs && json.docs.length > 0 && json.docs[0].key) {",
                  "    pm.collectionVariables.set('bookKey', json.docs[0].key);",
                  "}"
                ]
              }
            }
          ]
        },
